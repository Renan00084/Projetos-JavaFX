<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="480.0" prefWidth="560.0" spacing="20.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="org.example.tabela.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label fx:id="welcomeText" text="Lista de Usuários">
      <VBox.margin>
         <Insets bottom="50.0" />
      </VBox.margin></Label>
   <HBox prefHeight="49.0" prefWidth="520.0">
      <children>
         <VBox prefHeight="200.0" prefWidth="200.0">
            <children>
               <Label text="Digite o nome:">
                  <VBox.margin>
                     <Insets bottom="10.0" />
                  </VBox.margin>
               </Label>
               <TextField fx:id="tNome" onAction="#textField" onKeyPressed="#textField" promptText="_______________" />
            </children>
            <HBox.margin>
               <Insets right="10.0" />
            </HBox.margin>
         </VBox>
         <VBox prefHeight="200.0" prefWidth="200.0">
            <children>
               <Label text="Digite o email:">
                  <VBox.margin>
                     <Insets bottom="10.0" />
                  </VBox.margin>
               </Label>
               <TextField fx:id="tEmail" onAction="#onHelloButtonClick" promptText="_______________" />
            </children>
            <HBox.margin>
               <Insets right="10.0" />
            </HBox.margin>
         </VBox>
          <Button disable="true" onAction="#onHelloButtonClick" text="Atualizar Tabela">
            <HBox.margin>
               <Insets top="27.0" />
            </HBox.margin>
         </Button>
      </children>
      <VBox.margin>
         <Insets bottom="50.0" />
      </VBox.margin>
   </HBox>
   <TableView fx:id="tabela" prefHeight="200.0" prefWidth="183.0">
     <columns>
       <TableColumn fx:id="colNome" prefWidth="260.0" text="Nome" />
       <TableColumn fx:id="colEmail" prefWidth="260.0" text="Email" />
     </columns>
   </TableView>
</VBox>
